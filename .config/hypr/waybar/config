{
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 4,
    "margin-top": 5,
    "margin-left": 10,
    "margin-right": 10,
    "modules-left":  ["custom/launcher", "hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["custom/weather", "custom/cpu", "custom/ram", "tray", "network", "pulseaudio", "battery", "custom/powermenu"],

    "custom/launcher": {
        "format": "󰣇",
        "on-click": "~/.config/hypr/scripts/rofi-launcher.sh",
        "tooltip": false
    },
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "一",
            "2": "二",
            "3": "三",
            "4": "四",
            "5": "五",
            "default": "○"
        }
    },
    "hyprland/window": {
        "max-length": 50
    },
    "clock": {
        "format": "{:%I:%M %p}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "network": {
        "format-wifi": "󰤨 {essid}",
        "format-disconnected": "󰤮 Disconnected",
        "on-click": "nm-connection-editor"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟 Muted",
        "format-icons": {
            "default": ["󰕿", "󰖀", "󰕾"]
        },
        "on-click": "pavucontrol"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-icons": ["󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"]
    },
    "tray": {
        "spacing": 8
    },
    "custom/powermenu": {
        "format": "",
        "on-click": "~/.config/hypr/scripts/rofi-powermenu.sh",
        "tooltip": false
    },
    "custom/cpu": {
        "exec": "~/.config/hypr/waybar/scripts/cpu.sh",
        "interval": 5,
        "format": " {}"
    },
    "custom/ram": {
        "exec": "~/.config/hypr/waybar/scripts/ram.sh",
        "interval": 5,
        "format": " {}"
    },
    "custom/weather": {
        "exec": "~/.config/hypr/waybar/scripts/weather.sh",
        "interval": 1800,
        "format": "{}"
    }
}
